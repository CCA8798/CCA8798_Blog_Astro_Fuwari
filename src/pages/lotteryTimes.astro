---
// src/pages/dashboard.astro

import Markdown from "@components/misc/Markdown.astro";
import MainGridLayout from "../layouts/MainGridLayout.astro";
---

<MainGridLayout title="抽奖名单" description="抽奖名单&开奖时间" noindex>
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
        <div class="card-base z-10 px-9 py-6 relative w-full">
            <h1 class="text-3xl font-bold mb-8 text-center text-gray-900 dark:text-gray-100">🍥1100 Followers抽奖の名单🍥</h1>
            <h3 class="text-xl font-semibold text-gray-600 dark:text-gray-300 mb-4 text-center">开奖时间：2026/07/13 00:00(UTC+8)<br>❤️感谢有您❤️</h3>
            <Markdown class="prose dark:prose-invert max-w-none">
    
            <!-- 数据容器 -->
            <div id="names-container" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-1.5">
            <p class="text-gray-500 col-span-full text-center">正在加载名单...</p>
            </div>

            <p class="text-xs text-gray-400 text-center mt-8">
            数据每 2 分钟自动fetch一次<br>
            由于数据需要人工修改，故该页面显示的名单可能会有延迟
            </p>
            </Markdown>
        </div>
    </div>
</MainGridLayout>

<script>
  function copyProfileUrl(url: string, btn: HTMLElement) {
    navigator.clipboard.writeText(url).then(() => {
      const original = btn.innerHTML;
      btn.innerHTML = `<svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>`;
      btn.title = "已复制";
      setTimeout(() => { btn.innerHTML = original; btn.title = "复制链接"; }, 1500);
    }).catch(() => {
      // 降级：选中文本提示手动复制
      const input = document.createElement('input');
      input.value = url;
      document.body.appendChild(input);
      input.select();
      document.execCommand('copy');
      document.body.removeChild(input);
      const original = btn.innerHTML;
      btn.innerHTML = `<svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>`;
      btn.title = "已复制";
      setTimeout(() => { btn.innerHTML = original; btn.title = "复制链接"; }, 1500);
    });
  }

function renderNames(names: string[]) {
  const container = document.getElementById('names-container');
  if (!container) return;

  if (!Array.isArray(names) || names.length === 0) {
    container.innerHTML = '<p class="text-gray-500 col-span-full text-center">当前没有名单数据</p>';
    return;
  }

  container.innerHTML = names.map((name, index) => {
    // 去掉开头的 @ 符号，得到纯用户名
    const username = name.startsWith('@') ? name.slice(1) : name;
    const profileUrl = `https://x.com/${encodeURIComponent(username)}`;
    const escapedUsername = escapeHtml(username);
    
    return `
      <div class="bg-white dark:bg-gray-800 shadow-sm rounded-lg p-2 flex items-center gap-1
                  border border-gray-100 dark:border-gray-700 hover:shadow-md transition-all
                  hover:border-blue-400 dark:hover:border-blue-500 min-w-0">
        <span class="text-sm font-mono text-gray-300 dark:text-gray-600 shrink-0">#${index + 1}</span>
        <a href="${profileUrl}" target="_blank" rel="noopener noreferrer"
           class="flex-1 text-xs font-medium !text-gray-800 dark:!text-gray-100 no-underline hover:!text-blue-500 dark:hover:!text-blue-400 truncate min-w-0">
          @${escapedUsername}
        </a>
        <button onclick="copyProfileUrl('${profileUrl.replace(/'/g, "\\'")}', this)"
                class="shrink-0 p-0.5 rounded text-gray-400 hover:text-blue-500 hover:bg-blue-50 dark:hover:bg-blue-900/30 transition-colors"
                title="复制链接">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
          </svg>
        </button>
        <a href="${profileUrl}" target="_blank" rel="noopener noreferrer"
           class="shrink-0 p-0.5 rounded text-gray-400 hover:text-blue-500 hover:bg-blue-50 dark:hover:bg-blue-900/30 transition-colors"
           title="在 X 上打开">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    `;
  }).join('');
}

  // 防止 XSS（虽然 JSON 数据应该是安全的，但保留好习惯）
  function escapeHtml(text: string) {
    const div = document.createElement('div');
    div.appendChild(document.createTextNode(text));
    return div.innerHTML;
  }

  async function fetchData() {
    try {
      const response = await fetch('/api/status.json');
      if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);
      const data = await response.json();
      renderNames(data);   // 直接传入数组
    } catch (error) {
      console.error('获取名单失败:', error);
      const container = document.getElementById('names-container');
      if (container) {
        container.innerHTML = '<p class="text-red-500 col-span-full text-center">⚠️ 数据加载失败，请稍后再试</p>';
      }
    }
  }

  // 页面加载时立刻拉取一次
  document.addEventListener('DOMContentLoaded', fetchData);
  // 每 2 分钟刷新一次
  setInterval(fetchData, 120000);
</script>