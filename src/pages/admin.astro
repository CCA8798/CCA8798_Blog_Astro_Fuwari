---
import AdminPanel from "@components/AdminPanel.svelte";
import Layout from "@layouts/Layout.astro";
---

<style is:global>
	#admin-loading-wrapper {
		position: relative;
		min-height: 60vh;
	}
	#admin-loading {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	#admin-loading .spinner {
		width: 40px;
		height: 40px;
		border: 3px solid var(--line-color);
		border-top-color: var(--primary);
		border-radius: 50%;
		animation: spin 0.8s linear infinite;
	}
	@keyframes spin {
		to { transform: rotate(360deg); }
	}
	#admin-root:not(:empty) + #admin-loading {
		display: none;
	}
</style>

<Layout title="后台管理">
	<div id="admin-loading-wrapper">
		<div id="admin-root">
			<AdminPanel client:only="svelte" />
		</div>
		<div id="admin-loading">
			<div class="spinner"></div>
		</div>
	</div>
</Layout>
